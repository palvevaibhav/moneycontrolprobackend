# ─── Server ───────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# ─── MySQL ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=money_control_pro
DB_USER=root
DB_PASSWORD=your_strong_password
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_ACQUIRE_TIMEOUT=30000
DB_IDLE_TIMEOUT=10000

# ─── JWT ──────────────────────────────────────────────
JWT_ACCESS_SECRET=replace_with_64_char_random_hex_string
JWT_REFRESH_SECRET=replace_with_another_64_char_random_hex_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Google Gemini ────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.3
GEMINI_MAX_TOKENS=2048

# ─── ChromaDB (Vector Store) ──────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=money_control_embeddings
CHROMA_AUTH_TOKEN=

# ─── Redis (Optional caching) ─────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL_DEFAULT=3600
REDIS_TTL_ANALYTICS=1800

# ─── Rate Limiting ────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_AI_MAX=20

# ─── Logging ──────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

# ─── BCRYPT ───────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── Embedding ────────────────────────────────────────
EMBEDDING_DIMENSION=768

# ─── CORS ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173